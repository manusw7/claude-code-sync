#!/bin/bash
# Claude Code Conversation Sync - Pull
# Syncs conversations from the repo into each configured profile dir.

set -e

ORIGINAL_DIR="$(pwd)"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load configuration
source "$SCRIPT_DIR/lib-claude-sync.sh"

# Handle --version flag
if [ "$1" = "--version" ] || [ "$1" = "-v" ]; then
    show_version "$SCRIPT_DIR" "claude-sync-pull"
    exit 0
fi

load_config "$SCRIPT_DIR"

REPO_DIR="$SCRIPT_DIR/conversations"

echo "=== Claude Code Conversation Sync - Pull ==="
echo "Repo: $REPO_DIR"
echo ""

log_verbose "Using branch: $CLAUDE_SYNC_BRANCH"

# Check if repo is initialized
if [ ! -d "$REPO_DIR/.git" ]; then
    echo "Error: Conversations repository not initialized."
    echo ""
    echo "Run 'claude-sync-init' first to set up the repository."
    cd "$ORIGINAL_DIR"
    exit 1
fi

cd "$REPO_DIR"

# Check if encrypted repo is locked
if [ -d ".git/git-crypt" ]; then
    if git-crypt status 2>/dev/null | grep -q "not decrypted"; then
        echo "Error: Repository is encrypted but locked."
        echo ""
        echo "Unlock first with: claude-restore-encryption-key"
        echo "Or manually: cd $REPO_DIR && git-crypt unlock ~/.claude-git-crypt.key"
        cd "$ORIGINAL_DIR"
        exit 1
    fi
fi

# Pull from remote
if git remote | grep -q origin 2>/dev/null; then
    echo "Pulling from remote..."
    git pull origin "$CLAUDE_SYNC_BRANCH" 2>/dev/null || {
        echo "Warning: Could not pull. Using local copy."
    }
else
    echo "No git remote configured. Using local copy."
fi

cd "$SCRIPT_DIR"

# Populate SYNC_PROFILES
parse_profiles
if [ "${#SYNC_PROFILES[@]}" -eq 0 ]; then
    echo "Error: No sync profiles configured."
    cd "$ORIGINAL_DIR"
    exit 1
fi

# Sync each profile
for profile in "${SYNC_PROFILES[@]}"; do
    SUBDIR="$(profile_subdir "$profile")"
    SRC="$REPO_DIR/$SUBDIR"

    echo ""
    echo "--- Profile: $SUBDIR/ -> $profile ---"

    if [ ! -d "$SRC" ]; then
        echo "No data in repo for this profile yet. Skipping."
        continue
    fi

    mkdir -p "$profile"

    if [ -d "$SRC/projects" ]; then
        echo "Syncing project conversations..."
        rsync -av --update "$SRC/projects/" "$profile/projects/"
    fi

    if [ -d "$SRC/file-history" ]; then
        echo "Syncing file history..."
        rsync -av --update "$SRC/file-history/" "$profile/file-history/"
    fi

    if [ -d "$SRC/todos" ]; then
        echo "Syncing todos..."
        rsync -av --update "$SRC/todos/" "$profile/todos/"
    fi

    if [ -f "$SRC/history.jsonl" ]; then
        echo "Syncing global history..."
        if [ -f "$profile/history.jsonl" ]; then
            cat "$profile/history.jsonl" "$SRC/history.jsonl" | \
                sort -u > "$profile/history.jsonl.tmp"
            mv "$profile/history.jsonl.tmp" "$profile/history.jsonl"
        else
            cp "$SRC/history.jsonl" "$profile/history.jsonl"
        fi
    fi

    chmod -R u+rwX,go-rwx "$profile/projects" 2>/dev/null || true
    chmod -R u+rwX,go-rwx "$profile/file-history" 2>/dev/null || true
    chmod -R u+rwX,go-rwx "$profile/todos" 2>/dev/null || true
done

echo ""
echo "Sync complete!"
echo ""
echo "Note: Restart Claude Code to see the synced conversations."

cd "$ORIGINAL_DIR"
